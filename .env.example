# Copier vers .env.local et remplir les valeurs (Supabase : Project Settings → API).
# Après toute modification : arrêter puis relancer `npm run dev` (les NEXT_PUBLIC_* sont figées au démarrage).

# Vérification rapide : ouvrir http://localhost:3000/api/health/supabase
# → projectRef doit être le même que l’identifiant de projet dans l’URL du dashboard Supabase.

# Avec Supabase configuré, les données réelles sont utilisées par défaut côté client et serveur.
# Pour forcer les mocks malgré tout : NEXT_PUBLIC_USE_MOCKS=true
# NEXT_PUBLIC_USE_MOCKS=

# (Serveur uniquement, sans NEXT_PUBLIC_) — équivalent si vous n’utilisez pas le client navigateur
# USE_MOCKS=

# URL du projet (ex. golaine_prod — ref dans le dashboard Supabase)
NEXT_PUBLIC_SUPABASE_URL=https://qnvaclyfygkwkkxfjood.supabase.co

# Clé anon (public, respecte RLS) — ne jamais committer la vraie clé
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Où voir les comptes : Supabase Dashboard → Authentication → Users (pas Table Editor par défaut).
# Si l’e-mail doit être confirmé avant session : Authentication → Providers → Email → désactiver
# « Confirm email » en dev, ou confirmer le mail puis se connecter.

# Optionnel : clé service_role UNIQUEMENT côté serveur (routes API / scripts), jamais NEXT_PUBLIC_*
# SUPABASE_SERVICE_ROLE_KEY=

# URL de l’app (redirections, liens absolus)
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- WhatsApp (Evolution API — QR réel, routes /api/whatsapp/*) ---
# URL de votre instance Evolution API (ex. https://evolution.votredomaine.com)
# WHATSAPP_API_URL=
# Clé API (header apikey) — jamais en NEXT_PUBLIC_
# WHATSAPP_API_KEY=
# URL publique de l'app (obligatoire pour le webhook : ngrok en local, domaine en prod)
# NEXT_PUBLIC_APP_URL=https://votre-app.vercel.app
# Secret optionnel vérifié sur POST /api/webhooks/whatsapp (header x-webhook-secret)
# WHATSAPP_WEBHOOK_SECRET=

# --- Gemini (phase suivante ; la route /api/chat les utilise déjà) ---
# GEMINI_API_KEY=
# Modèle recommandé (free tier) — éviter gemini-2.0-flash (quota 0)
# GEMINI_MODEL=gemini-2.5-flash
